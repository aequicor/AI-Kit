CREATE TABLE document (
    id TEXT NOT NULL PRIMARY KEY,
    path TEXT NOT NULL,
    name TEXT NOT NULL,
    lastOpened INTEGER NOT NULL
);

insertOrReplace:
INSERT OR REPLACE INTO document(id, path, name, lastOpened)
VALUES (?, ?, ?, ?);

selectById:
SELECT * FROM document WHERE id = ?;

selectAll:
SELECT * FROM document ORDER BY lastOpened DESC;
