{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aequicor/ai-agent-kit/manifest.schema.json",
  "title": "AI Agent Kit Manifest",
  "description": "Schema for ai-agent-kit manifest YAML files",
  "type": "object",
  "required": ["kit_version", "hosts", "project", "stack", "modules"],
  "properties": {
    "kit_version": {
      "type": "string",
      "description": "Kit version — used for migration checks",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "hosts": {
      "type": "array",
      "description": "Runtime hosts the project supports. The kit renders one template tree per host into the target. opencode → .opencode/ tree + opencode.json. claude-code → .claude/ tree + .claude/settings.json + CLAUDE.md (main-session orchestrator). Multi-host installs render both side-by-side.",
      "items": {
        "type": "string",
        "enum": ["opencode", "claude-code"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "vault_path": {
      "type": "string",
      "description": "Root path (relative to project) where KnowledgeOS stores all docs. Default: vault (matches KnowledgeOS out-of-the-box). Legacy: .vault",
      "default": "vault",
      "minLength": 1
    },
    "language_code": {
      "type": "string",
      "description": "Agent output language (IETF language tag). Embedded into _shared.md so agents use the matching i18n locale. Supported: en (English), ru (Russian).",
      "enum": ["en", "ru"],
      "default": "en"
    },
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string"}
      }
    },
    "stack": {
      "type": "object",
      "required": ["language", "build_command", "compile_command", "lint_command", "test_command"],
      "properties": {
        "language": {
          "type": "string",
          "enum": ["kotlin", "python", "typescript", "go", "rust", "java", "generic"]
        },
        "profiles": {
          "type": "array",
          "description": "List of profile names to merge. Each profile declares an _profile_axis (language|framework|provider|capability). Cardinality rules: exactly one language profile, exactly one provider profile, zero or more framework profiles, zero or more capability profiles. Within a single axis, fields are exclusive (no overlap), so merge order within an axis is irrelevant; across axes, each axis owns disjoint fields. Manifest values still win over any merged profile value.",
          "items": {"type": "string"},
          "minItems": 1,
          "uniqueItems": true
        },
        "external_profiles": {
          "type": "object",
          "description": "Map of profile name → source URL for profiles fetched from outside the kit repo via /kit-extend. Names here MUST also appear in stack.profiles. Used by /kit-update so external profiles can be re-validated without 404s on RAW_BASE/profiles/<axis>/<name>.yaml.",
          "additionalProperties": {
            "type": "string",
            "format": "uri",
            "pattern": "^https?://"
          }
        },
        "build_command": {"type": "string", "minLength": 1},
        "compile_command": {"type": "string", "minLength": 1},
        "lint_command": {"type": "string", "minLength": 1},
        "test_command": {"type": "string", "minLength": 1}
      }
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source_root", "test_root", "docs_path"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "gradle_module": {
            "oneOf": [
              {"type": "string", "pattern": "^:"},
              {"type": "null"}
            ]
          },
          "source_root": {"type": "string", "minLength": 1},
          "test_root": {"type": "string", "minLength": 1},
          "docs_path": {"type": "string", "minLength": 1},
          "responsibility": {"type": "string"},
          "conventions": {"type": "string"},
          "module_dependencies": {"type": "string"}
        }
      }
    },
    "provider": {
      "type": "object",
      "description": "OpenCode provider config. Required iff 'opencode' ∈ hosts. Ignored when only 'claude-code' is in hosts (Claude Code uses Anthropic native models via the Claude Code CLI/desktop).",
      "required": ["name", "base_url", "api_key_env"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "base_url": {"type": "string", "format": "uri", "pattern": "^https?://"},
        "api_key_env": {"type": "string", "minLength": 1}
      }
    },
    "models": {
      "type": "object",
      "description": "OpenCode model role assignments (used as {{PROVIDER_ID}}/{{MODEL}} in opencode.json and agent frontmatter). Required iff 'opencode' ∈ hosts.",
      "required": ["default", "coder", "reviewer"],
      "properties": {
        "default": {"type": "string", "minLength": 1},
        "coder": {"type": "string", "minLength": 1},
        "reviewer": {"type": "string", "minLength": 1},
        "designer": {
          "oneOf": [
            {"type": "string", "minLength": 1},
            {"type": "null"}
          ]
        },
        "small": {"type": "string"}
      }
    },
    "claude_code": {
      "type": "object",
      "description": "Claude Code runtime config. Required iff 'claude-code' ∈ hosts. Models accept the Claude Code CLI aliases (opus | sonnet | haiku) or full model IDs (e.g. claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5).",
      "required": ["models"],
      "properties": {
        "models": {
          "type": "object",
          "required": ["default", "coder", "reviewer"],
          "properties": {
            "default": {"type": "string", "minLength": 1},
            "coder": {"type": "string", "minLength": 1},
            "reviewer": {"type": "string", "minLength": 1},
            "designer": {
              "oneOf": [
                {"type": "string", "minLength": 1},
                {"type": "null"}
              ]
            },
            "small": {"type": "string"}
          }
        }
      }
    },
    "mcp": {
      "type": "object",
      "properties": {
        "context7": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "api_key_env": {"type": "string"}
          }
        },
        "knowledge": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "url": {"type": "string", "format": "uri"}
          }
        },
        "serena": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"}
          }
        }
      }
    },
    "lsp": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "command": {"type": "string"},
        "extensions": {
          "type": "array",
          "items": {"type": "string", "pattern": "^\\."}
        }
      }
    },
    "ui": {
      "type": "object",
      "properties": {
        "framework": {
          "oneOf": [
            {"type": "string", "minLength": 1},
            {"type": "null"}
          ]
        },
        "platforms": {
          "type": "array",
          "items": {"type": "string"}
        },
        "colors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "hex", "purpose"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "hex": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
              "purpose": {"type": "string"}
            }
          }
        }
      }
    },
    "code_quality": {
      "type": "object",
      "properties": {
        "forbidden_patterns": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "formatter": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "name": {"type": "string"},
        "command": {
          "type": "array",
          "items": {"type": "string"}
        },
        "extensions": {
          "type": "array",
          "items": {"type": "string", "pattern": "^\\."}
        }
      }
    }
  },
  "allOf": [
    {
      "description": "If opencode is in hosts, provider/models must be present.",
      "if": {
        "properties": {"hosts": {"type": "array", "contains": {"const": "opencode"}}},
        "required": ["hosts"]
      },
      "then": {"required": ["provider", "models"]}
    },
    {
      "description": "If claude-code is in hosts, claude_code block must be present.",
      "if": {
        "properties": {"hosts": {"type": "array", "contains": {"const": "claude-code"}}},
        "required": ["hosts"]
      },
      "then": {"required": ["claude_code"]}
    }
  ]
}
