{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/kit-manifect.schema.json",
  "title": "Kit Manifect",
  "description": "Universal manifest for AI agent teams across runners, models, projects.",
  "type": "object",
  "required": ["manifest_version", "project", "targets", "providers", "models", "agents"],
  "properties": {
    "manifest_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "kit_version":      { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "language_code":    { "type": "string", "minLength": 2, "maxLength": 8 },
    "project": {
      "type": "object",
      "required": ["name", "slug"],
      "properties": {
        "name":        { "type": "string", "minLength": 1 },
        "slug":        { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "description": { "type": "string" },
        "repo_url":    { "type": "string", "format": "uri" },
        "owners":      { "type": "array", "items": { "type": "string" } }
      }
    },
    "stack":   { "type": "object" },
    "modules": { "type": "array",  "items": { "type": "object" } },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "native_provider"],
        "properties": {
          "id":              { "type": "string" },
          "native_provider": { "type": "string" },
          "can_use_via":     { "type": "array", "items": { "type": "string" } },
          "adapter":         { "type": "string" }
        }
      }
    },
    "render_targets":   { "type": "array", "items": { "type": "string" } },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "properties": {
          "id":               { "type": "string" },
          "kind":             { "type": "string" },
          "auth":             {
            "type": "string",
            "enum": ["api_key", "subscription", "none"],
            "description": "How the provider authenticates: api_key (env var), subscription (runner-managed login such as Claude Code or Cursor), or none (local backend)."
          },
          "base_url":         { "type": "string" },
          "api_key_env":      { "type": "string" },
          "timeout_seconds":  { "type": "integer", "minimum": 0 },
          "max_retries":      { "type": "integer", "minimum": 0 }
        },
        "if":   { "properties": { "auth": { "const": "api_key" } }, "required": ["auth"] },
        "then": { "required": ["api_key_env"] }
      }
    },
    "models":           { "type": "array", "minItems": 1 },
    "task_types":       { "type": "array" },
    "prompt_dialects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "properties": {
          "id":   { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "target_adapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "properties": {
          "id":   { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "shared":           { "type": "object", "properties": { "path": { "type": "string" } } },
    "agents":           { "type": "array", "minItems": 1 },
    "tools":            { "type": "array" },
    "workflows":        { "type": "array" },
    "knowledge":        { "type": "object" },
    "policies": {
      "type": "object",
      "properties": {
        "forbidden_patterns": { "type": "array", "items": { "type": "string" } },
        "secrets_policy":     { "type": "object" },
        "test_strategy":      { "type": "string" },
        "slice_caps":         { "type": "object" },
        "model_constraints":  { "type": "object" },
        "optional_skills": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Opt-in list of optional skill IDs to emit (e.g. debug-loop, tdd-cycle, security-checklist, doubt-driven-review, simplification-pass, adr-on-decision). Core skills emit regardless."
        },
        "permissions": {
          "type": "object",
          "description": "Runner-permission overrides on top of the kit's built-in pipeline allow-list (git verbs, Skill, Agent, TodoWrite, ExitPlanMode, file ops) and the stack-derived patterns (Bash(<build-tool>:*)). Use Claude Code grammar — adapters translate to per-runner formats (OpenCode nested object, etc.). Deny wins over allow. Note: AskUserQuestion and EnterPlanMode are UX/AWAIT primitives that Claude Code auto-allows and its settings.json schema rejects in `permissions.allow` — do not add them here.",
          "properties": {
            "allow": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Extra always-allowed patterns. Examples: \"Bash(docker:*)\", \"mcp__playwright__*\", \"WebFetch(domain:internal.corp)\"."
            },
            "deny": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Hard-deny patterns. Examples: \"Bash(rm -rf:*)\", \"Bash(curl:*)\", \"mcp__untrusted__*\"."
            }
          }
        }
      }
    },
    "workspace":        { "type": "object" },
    "extends":          { "type": "array", "items": { "type": "string" } },
    "x":                { "type": "object" }
  }
}
